# ============================================================
# Spendly v4 - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://godwinagbane:@localhost:5432/spendly_v4

# --- Server ---
PORT=3000
NODE_ENV=development
SESSION_SECRET=your-session-secret-change-in-production
APP_URL=http://localhost:3000

# --- AWS Cognito (Server - JWT Verification) ---
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id

# --- AWS Cognito (Client - Web SDK) ---
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_COGNITO_DOMAIN=your-app.auth.us-east-1.amazoncognito.com

# --- Stripe ---
# Get these from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_your_identity_webhook_secret

# --- Paystack ---
# Get these from Paystack Dashboard > Settings > API Keys
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# --- AWS (Email & SMS via SES/SNS) ---
# For local dev: provide explicit credentials
# On ECS/Lambda: omit these — SDK auto-discovers from IAM task role
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_SES_FROM_NAME=Spendly
AWS_SNS_SENDER_ID=Spendly
